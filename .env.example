# Copy to .env.local for development. On Vercel, set for Production
# (and Preview if you use branch deploys), then redeploy.

# Preferred (inlined into the browser bundle at build time):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_from_supabase_dashboard

# Alternative (server-only names — the app exposes them via /api/auth/supabase-config):
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=your_anon_key

# Canonical site URL for email confirmation redirects (optional locally)
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
