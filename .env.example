# Copy to .env.local for development. On Vercel, set for Production
# (and Preview if you use branch deploys), then redeploy.
#
# Email: Supabase SMTP (Gmail, Workspace, Resend, etc.) is set in the dashboard only.
# See SUPABASE_EMAIL_SETUP.md for the full checklist.
#
# ---------------------------------------------------------------------------
# CRITICAL — two different URLs (do not mix them up):
#
#   NEXT_PUBLIC_SUPABASE_URL  = Supabase project API host
#       Dashboard → Project Settings → API → "Project URL"
#       Looks like: https://xxxxx.supabase.co  (ends in .co — not .com)
#
#   NEXT_PUBLIC_BASE_URL      = YOUR website (optional)
#       e.g. https://www.yoursite.com — used for auth redirect links on the server.
#       This does NOT connect the app to Supabase. If Supabase vars are missing,
#       sign-in stays broken no matter what BASE_URL is set to.
# ---------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_from_supabase_dashboard

# Optional: canonical URL of this app (see lib/site-config.ts).
# With or without https:// — e.g. https://www.example.com or www.example.com
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Server-only: Stripe webhooks, membership sync (see lib/supabase/admin.ts)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
